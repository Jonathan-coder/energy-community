<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="at.fhtw.energygui.HelloController">
  <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

  <Label text="Energy Community Monitor" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
  <Label fx:id="labelStatus" text="Loading data..." wrapText="true"/>

  <TitledPane text="Current Community Status" collapsible="false">
    <VBox spacing="8">
      <Button text="Refresh Current" onAction="#loadCurrent"/>
      <Label fx:id="labelCurrent" text="Press Refresh to load data" wrapText="true"/>
    </VBox>
  </TitledPane>

  <TitledPane text="Historical Usage" collapsible="false">
    <VBox spacing="8">
      <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="From:"/>
        <DatePicker fx:id="startDatePicker"/>
        <Label text="To:"/>
        <DatePicker fx:id="endDatePicker"/>
        <Button text="Load Historical" onAction="#loadHistorical"/>
      </HBox>
      <TableView fx:id="tableHistorical" prefHeight="260">
        <columns>
          <TableColumn fx:id="colHour" text="Period" prefWidth="180"/>
          <TableColumn fx:id="colProduced" text="Produced (kWh)" prefWidth="140"/>
          <TableColumn fx:id="colUsed" text="Used (kWh)" prefWidth="120"/>
          <TableColumn fx:id="colGrid" text="Grid (kWh)" prefWidth="120"/>
        </columns>
      </TableView>
    </VBox>
  </TitledPane>
</VBox>
